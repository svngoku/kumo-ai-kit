{
  "name": "kumo-ai-kit",
  "version": "0.1.0",
  "description": "A soft, high-level React component suite for building AI platforms — powered by Cloudflare's Kumo design system.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "react",
    "kumo",
    "cloudflare",
    "ai",
    "components",
    "design-system",
    "chat",
    "llm"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/ai-kit.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run typecheck && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && cp src/lib/styles/ai-kit.css dist/ai-kit.css",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svngoku/kumo-ai-kit.git"
  },
  "homepage": "https://github.com/svngoku/kumo-ai-kit#readme",
  "peerDependencies": {
    "@cloudflare/kumo": ">=2.7.0",
    "@phosphor-icons/react": ">=2.1.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "@cloudflare/kumo": "^2.7.0",
    "@phosphor-icons/react": "^2.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.2",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.0"
  }
}
